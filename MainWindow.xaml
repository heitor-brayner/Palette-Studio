<Window
    x:Class="PaletteStudio.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PaletteStudio"
    Title="Palette Studio">

    <Grid>
        <!-- Custom title bar region -->
        <Grid x:Name="AppTitleBar"
              Height="48"
              VerticalAlignment="Top"
              Canvas.ZIndex="1"
              IsHitTestVisible="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPaddingColumn" Width="0"/>
                <ColumnDefinition/>
                <ColumnDefinition x:Name="RightPaddingColumn" Width="0"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Spacing="10"
                        Margin="12,0">
                <FontIcon Glyph="&#xE790;" FontSize="16" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                <TextBlock Text="Palette Studio"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
            </StackPanel>
        </Grid>

        <NavigationView x:Name="NavView"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        PaneDisplayMode="Left"
                        OpenPaneLength="220"
                        SelectionChanged="NavView_SelectionChanged"
                        AutomationProperties.Name="Main navigation">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="PaletteNavItem"
                                    Tag="PalettePage"
                                    Content="Palette"
                                    AutomationProperties.Name="Palette page">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE790;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="ExportNavItem"
                                    Tag="ExportPage"
                                    Content="Export"
                                    AutomationProperties.Name="Export page">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE74E;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="SettingsNavItem"
                                    Tag="SettingsPage"
                                    Content="Settings"
                                    AutomationProperties.Name="Settings page">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <!-- Content frame; top margin leaves room for custom title bar -->
            <Frame x:Name="ContentFrame"
                   Margin="0,48,0,0"
                   AutomationProperties.Name="Page content"/>
        </NavigationView>
    </Grid>
</Window>
