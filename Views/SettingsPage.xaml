<Page
    x:Class="PaletteStudio.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="{StaticResource SpacingL}" Padding="32,24" MaxWidth="640" HorizontalAlignment="Stretch">

            <!-- ── Page header ───────────────────────────────────── -->
            <TextBlock Text="Settings"
                       Style="{StaticResource TitleTextBlockStyle}"/>

            <!-- ── Appearance ─────────────────────────────────────── -->
            <Border Style="{StaticResource PageCardStyle}">
                <StackPanel Spacing="{StaticResource SpacingM}">
                    <TextBlock Text="Appearance"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <StackPanel Spacing="{StaticResource SpacingS}">
                        <TextBlock Text="App theme"
                                   Style="{StaticResource BodyTextBlockStyle}"/>
                        <RadioButtons x:Name="ThemeRadioButtons"
                                      SelectedIndex="{x:Bind ViewModel.ThemeIndex, Mode=TwoWay}"
                                      AutomationProperties.Name="App theme selector">
                            <RadioButton Content="System default"
                                         AutomationProperties.Name="System default theme"/>
                            <RadioButton Content="Light"
                                         AutomationProperties.Name="Light theme"/>
                            <RadioButton Content="Dark"
                                         AutomationProperties.Name="Dark theme"/>
                        </RadioButtons>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── About ──────────────────────────────────────────── -->
            <Border Style="{StaticResource PageCardStyle}">
                <StackPanel Spacing="{StaticResource SpacingM}">
                    <TextBlock Text="About"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <Grid ColumnSpacing="{StaticResource SpacingM}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- App icon placeholder -->
                        <Border Grid.Column="0"
                                Width="64" Height="64"
                                CornerRadius="{StaticResource CornerRadiusCard}"
                                Background="{ThemeResource AccentFillColorDefaultBrush}">
                            <FontIcon Glyph="&#xE790;"
                                      FontSize="32"
                                      Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                    Spacing="{StaticResource SpacingXS}">
                            <TextBlock Text="Palette Studio"
                                       Style="{StaticResource SubtitleTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneTime}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>

                    <HyperlinkButton Content="View on GitHub"
                                     Command="{x:Bind ViewModel.OpenGitHubCommand}"
                                     AutomationProperties.Name="Open GitHub repository"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
