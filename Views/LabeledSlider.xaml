<!-- Reusable labeled slider control used by ColorDetailPage -->
<UserControl
    x:Class="PaletteStudio.Views.LabeledSlider"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="40"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="{x:Bind Label, Mode=OneWay}"
                   VerticalAlignment="Center"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

        <Slider Grid.Column="1"
                Value="{x:Bind Value, Mode=TwoWay}"
                Minimum="{x:Bind Minimum, Mode=OneTime}"
                Maximum="{x:Bind Maximum, Mode=OneTime}"
                AutomationProperties.Name="{x:Bind AutomationName, Mode=OneTime}"
                VerticalAlignment="Center"/>

        <TextBlock Grid.Column="2"
                   Text="{x:Bind Value, Mode=OneWay, Converter={StaticResource DoubleToIntStringConverter}}"
                   VerticalAlignment="Center"
                   TextAlignment="Right"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   FontFamily="Cascadia Code, Consolas"/>
    </Grid>
</UserControl>
